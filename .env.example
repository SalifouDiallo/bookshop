# Fichier de configuration d'environnement — Bookshop
# Copier ce fichier en .env et ajuster les valeurs selon votre environnement.
# Le fichier .env ne doit JAMAIS être commité dans Git.

# Environnement d'exécution : development | production
FLASK_ENV=development

# Nom du fichier de base de données SQLite
DB_FILE=bookshop.db

# Taux de taxes combinées (TPS + TVQ, Québec)
TAXE_TOTALE=0.14975

# Frais de livraison en centimes (500 = 5,00 $)
LIVRAISON_CENTS=500

# Devise
CURRENCY=CAD

# Limite d'articles distincts par commande
MAX_ITEMS_PER_ORDER=50
